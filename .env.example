# Scanner thresholds
POLY_ODDS_CHANGE_THRESHOLD=8
POLY_TIME_WINDOW_MINUTES=60
POLY_WHALE_THRESHOLD_USD=25000
POLY_MARKET_RELEVANCE_THRESHOLD=0.4

# Job schedules (cron syntax)
JOB_SCAN_CRON="*/15 * * * *"
JOB_MARKET_REFRESH_CRON="0 */6 * * *"
JOB_INSTRUMENT_REFRESH_CRON="0 6 * * *"
JOB_CLEANUP_CRON="0 3 * * *"

# Avanza credentials (optional — leave blank to run without Avanza)
AVANZA_USERNAME=your_avanza_username
AVANZA_PASSWORD=your_avanza_password
AVANZA_TOTP_SECRET=your_totp_secret_base32
AVANZA_SEARCH_DELAY_MS=2000
AVANZA_BASE_URL=https://www.avanza.se

# Alerts
ALERT_MIN_CONFIDENCE=50
ALERT_PUSHOVER_USER_KEY=
ALERT_PUSHOVER_APP_TOKEN=
ALERT_WEBHOOK_URL=
VERIFICATION_REQUIRED_FOR_PUSH=true
ENTITY_CONFIDENCE_THRESHOLD=0.55
UNKNOWN_PERSON_LEGAL_EVENT_POLICY=block

# Server
API_PORT=3100
NODE_ENV=development
PUBLIC_URL=http://localhost:3100

# Home Assistant
HA_URL=http://homeassistant.local
HA_TOKEN=your_long_lived_access_token
HA_NOTIFY_SERVICE=notify.mobile_app_your_phone
ALERT_MIN_CONFIDENCE_HA=65
ALERT_MIN_CONFIDENCE_HA_INTRADAY=80
