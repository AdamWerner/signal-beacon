{
  "name": "polysignal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/dashboard",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:all": "npm run dev --workspace=packages/dashboard & npm run dev --workspace=packages/api",
    "build": "npm run build --workspaces",
    "build:dashboard": "npm run build --workspace=packages/dashboard",
    "build:api": "npm run build --workspace=packages/api",
    "build:scanner": "npm run build --workspace=packages/scanner",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "scan": "node scripts/run-scan.js",
    "refresh:instruments": "node scripts/refresh-instruments.js",
    "refresh:markets": "node scripts/refresh-markets.js",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
